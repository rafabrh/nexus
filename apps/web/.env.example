# ============================================
# NEXUS Web (Next.js) — Environment Variables
# ============================================

# Base URL da API. Inlined no bundle do cliente em BUILD time — em produção,
# precisa estar presente no build (no EasyPanel, como env do serviço web).
# Dev:
NEXT_PUBLIC_API_URL=http://localhost:4000
# Produção:
# NEXT_PUBLIC_API_URL=https://api.shkgroup.com.br

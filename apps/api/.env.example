# ============================================
# NEXUS API — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---- Postgres (sistema de registro do painel) ----
# Banco onde vivem tenants, usuarios, reminders, quick replies e a projecao de
# conversas. Crie um banco vazio (ex.: no pgAdmin) — as tabelas sao criadas no
# boot via migrate. As chaves do N8N continuam no Redis.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nexus

# ---- JWT ----
# IMPORTANT: Use a strong random secret in production (min 32 chars)
JWT_SECRET=change-me-to-a-strong-secret-min-32-characters
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Admin ----
ADMIN_EMAIL=admin@example.com

# ---- Dev seed (apenas fora de producao) ----
# Se SEED_INSTANCE estiver setado e nao houver tenants, semeia um tenant admin no
# boot para o login local funcionar contra um banco vazio. NUNCA setar em producao.
SEED_INSTANCE=nexusdev
SEED_ADMIN_EMAIL=admin@example.com

# ---- Evolution API ----
# URL of the Evolution API instance
EVOLUTION_API_URL=https://your-evolution-api.example.com
# API key for the Evolution API
EVOLUTION_API_KEY=your-evolution-api-key

# ---- Google Sheets (Leads) ----
# Google Sheets document ID for lead data
SHEETS_DOCUMENT_ID=your-google-sheets-document-id
# Service account JSON (inline JSON or path to .json file)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- Resend (Email) ----
# API key for Resend email service
RESEND_API_KEY=
RESEND_FROM=noreply@example.com

# ---- Magic Link ----
# Base URL for magic link callback (frontend URL)
MAGIC_LINK_BASE_URL=http://localhost:3000/auth/callback

# ---- App ----
APP_BASE_URL=http://localhost:4000
PORT=4000
LOG_LEVEL=debug

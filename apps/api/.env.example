# ============================================
# NEXUS API — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---- Postgres (sistema de registro do painel) ----
# Banco onde vivem tenants, usuarios, reminders, quick replies e a projecao de
# conversas. Crie um banco vazio (ex.: no pgAdmin) — as tabelas sao criadas no
# boot via migrate. As chaves do N8N continuam no Redis.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nexus

# ---- JWT ----
# IMPORTANT: Use a strong random secret in production (min 32 chars)
JWT_SECRET=change-me-to-a-strong-secret-min-32-characters
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Admin ----
ADMIN_EMAIL=admin@example.com

# ---- Dev seed (apenas fora de producao) ----
# Se SEED_INSTANCE estiver setado e nao houver tenants, semeia um tenant admin no
# boot para o login local funcionar contra um banco vazio. NUNCA setar em producao.
SEED_INSTANCE=nexusdev
SEED_ADMIN_EMAIL=admin@example.com

# ---- Evolution API ----
# URL of the Evolution API instance
EVOLUTION_API_URL=https://your-evolution-api.example.com
# API key for the Evolution API
EVOLUTION_API_KEY=your-evolution-api-key

# ---- Google Sheets (Leads) ----
# Google Sheets document ID for lead data
SHEETS_DOCUMENT_ID=your-google-sheets-document-id
# Service account JSON (inline JSON or path to .json file)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- Resend (Email) ----
# API key for Resend email service
RESEND_API_KEY=
RESEND_FROM=noreply@example.com

# ---- SMTP (email oficial; tem precedencia sobre Resend quando configurado) ----
# Ex.: Hostgator -> host mail.SEUDOMINIO; porta 465 (SSL, SMTP_SECURE=true) ou
# 587 (STARTTLS, SMTP_SECURE=false). SMTP_USER e a conta de email completa.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
# Remetente (cai para RESEND_FROM / SMTP_USER quando ausente):
MAIL_FROM=noreply@shkgroup.com.br

# ---- Magic Link ----
# Base URL for magic link callback (frontend URL)
MAGIC_LINK_BASE_URL=http://localhost:3000/auth/callback
# Janela (segundos) em que um novo pedido do MESMO email nao dispara outro
# email — evita lotar a caixa do cliente quando ele reclica "enviar". Default 90.
MAGIC_LINK_RESEND_COOLDOWN_SECONDS=90

# ---- App ----
APP_BASE_URL=http://localhost:4000
PORT=4000
LOG_LEVEL=debug

# ---- Reverse proxy (produção) ----
# Quantos proxies ficam na frente da API. EasyPanel/Traefik = 1 (default em
# produção quando não setado). Se colocar Cloudflare na frente do Traefik = 2.
# Sem isso o rate limit por-IP vira global atrás do proxy.
TRUST_PROXY=1

# ---- Métricas (/metrics) ----
# Em produção, /metrics exige este Bearer token. Se não setar, /metrics é negado.
METRICS_TOKEN=

# ============================================================
# BLOCO DE PRODUÇÃO (EasyPanel) — valores de exemplo p/ shkgroup.com.br
# ============================================================
# NODE_ENV=production
# JWT_SECRET=<openssl rand -base64 48>
# REDIS_URL=redis://:<senha>@<nome-interno-redis>:6379
# REDIS_PASSWORD=<senha forte>
# DATABASE_URL=postgres://nexus:<senha>@<nome-interno-postgres>:5432/nexus
# CORS_ALLOWED_ORIGINS=https://painel.shkgroup.com.br
# MAGIC_LINK_BASE_URL=https://painel.shkgroup.com.br/auth/callback
# APP_BASE_URL=https://api.shkgroup.com.br
# RESEND_FROM=noreply@shkgroup.com.br
# TRUST_PROXY=1
# (NÃO setar SEED_INSTANCE em produção)
